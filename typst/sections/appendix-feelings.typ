// Appendix A — Feelings Vocabulary (Rosenberg / CNVC)
#import "../utils.typ": appendix-heading, appendix-intro, appendix-column-header, ref-block

#appendix-heading("Feelings Vocabulary")

#appendix-intro[
  From Marshall Rosenberg and the Center for Nonviolent Communication. Two columns: what moves through you when your needs are met, and when they aren't.
]

#v(1.2em)

#grid(
  columns: (1fr, 1fr),
  column-gutter: 1.2em,
  row-gutter: 0em,
  [
    #ref-block[
      #set par(leading: 0.75em, spacing: 0.6em)
      #appendix-column-header("when needs are met")
      #v(0.5em)
      #set text(size: 10.5pt)
      *Affectionate:* compassionate, friendly, loving, open-hearted, tender, warm

      *Engaged:* absorbed, alert, curious, enthusiastic, fascinated, interested, stimulated

      *Hopeful:* encouraged, expectant, optimistic

      *Confident:* empowered, open, proud, safe, secure

      *Grateful:* appreciative, moved, thankful, touched

      *Inspired:* amazed, awed, wonder

      *Joyful:* amused, delighted, glad, happy, pleased, tickled

      *Exhilarated:* blissful, ecstatic, elated, radiant, thrilled

      *Peaceful:* calm, centered, comfortable, content, fulfilled, quiet, relaxed, relieved, satisfied, serene, still, trusting

      *Refreshed:* enlivened, rejuvenated, renewed, rested, restored, revived
    ]
  ],
  [
    #ref-block[
      #set par(leading: 0.75em, spacing: 0.6em)
      #appendix-column-header("when needs are not met")
      #v(0.5em)
      #set text(size: 10.5pt)
      *Afraid:* apprehensive, dread, frightened, panicked, scared, terrified, wary, worried

      *Angry:* enraged, furious, incensed, indignant, irate, livid, outraged, resentful

      *Annoyed:* aggravated, disgruntled, exasperated, frustrated, impatient, irritated

      *Aversion:* appalled, contempt, disgusted, horrified, hostile, repulsed

      *Confused:* ambivalent, baffled, bewildered, hesitant, lost, perplexed, torn

      *Disconnected:* alienated, apathetic, bored, detached, indifferent, numb, withdrawn

      *Disquiet:* agitated, alarmed, disturbed, rattled, restless, troubled, uneasy, unsettled

      *Embarrassed:* ashamed, chagrined, guilty, mortified, self-conscious

      *Fatigue:* burnt out, depleted, exhausted, lethargic, tired, weary

      *Pain:* anguished, bereaved, devastated, grief, heartbroken, hurt, lonely, miserable

      *Sad:* dejected, despondent, disappointed, discouraged, disheartened, forlorn, hopeless, melancholy, unhappy

      *Tense:* anxious, cranky, distressed, edgy, frazzled, nervous, overwhelmed, stressed

      *Vulnerable:* fragile, guarded, helpless, insecure, sensitive, shaky

      *Yearning:* envious, longing, nostalgic, pining, wistful
    ]
  ]
)
